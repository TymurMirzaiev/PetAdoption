@using PetAdoption.Web.BlazorApp.Models

<div class="pet-card">
    @* Photo / placeholder area *@
    <div class="pet-card__photo">
        @if (!string.IsNullOrEmpty(Pet.PrimaryPhotoUrl))
        {
            <img src="@Pet.PrimaryPhotoUrl" alt="@Pet.Name" class="pet-card__img" />
        }
        else
        {
            <div class="pet-card__no-photo">
                <MudIcon Icon="@Icons.Material.Filled.Pets" Style="font-size:64px;opacity:0.25;" />
            </div>
        }

        @* Media count badge *@
        @if (Pet.MediaCount > 1)
        {
            <div class="pet-card__media-badge">
                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Style="font-size:14px;margin-right:3px;" />
                @Pet.MediaCount
            </div>
        }

        @* Status chip *@
        <div class="pet-card__status-chip">
            <MudChip T="string" Size="Size.Small" Color="@PetDisplayHelpers.PetStatusColor(Pet.Status)"
                     Style="margin:0;font-size:11px;height:22px;">
                @Pet.Status
            </MudChip>
        </div>
    </div>

    @* Info area *@
    <div class="pet-card__info">
        <div class="pet-card__name">@Pet.Name</div>
        <div class="pet-card__type">@Pet.Type</div>
        <div class="pet-card__meta">
            @if (Pet.Breed is not null)
            {
                <span class="pet-card__meta-item">@Pet.Breed</span>
            }
            @if (Pet.AgeMonths.HasValue)
            {
                <span class="pet-card__meta-sep">·</span>
                <span class="pet-card__meta-item">@PetDisplayHelpers.FormatAge(Pet.AgeMonths.Value)</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Pet.Description))
        {
            <div class="pet-card__desc">@Pet.Description</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PetListItem Pet { get; set; } = null!;
    [Parameter] public bool ShowActions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
