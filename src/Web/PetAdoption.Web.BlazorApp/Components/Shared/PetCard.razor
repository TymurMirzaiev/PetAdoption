@using PetAdoption.Web.BlazorApp.Models

<MudCard Elevation="4" Style="width: 300px; height: 420px;" Class="d-flex flex-column">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Primary" Size="Size.Large">@Pet.Name[..1]</MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@Pet.Name</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Pet.Type</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="flex-grow-1">
        @if (Pet.Breed is not null)
        {
            <MudText Typo="Typo.body2"><b>Breed:</b> @Pet.Breed</MudText>
        }
        @if (Pet.AgeMonths.HasValue)
        {
            <MudText Typo="Typo.body2"><b>Age:</b> @FormatAge(Pet.AgeMonths.Value)</MudText>
        }
        @if (Pet.Description is not null)
        {
            <MudText Typo="Typo.body2" Class="mt-2">@Pet.Description</MudText>
        }
    </MudCardContent>
    @if (ShowActions)
    {
        <MudCardActions>
            @ChildContent
        </MudCardActions>
    }
</MudCard>

@code {
    [Parameter, EditorRequired] public PetListItem Pet { get; set; } = null!;
    [Parameter] public bool ShowActions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static string FormatAge(int months) =>
        months >= 12 ? $"{months / 12}y {months % 12}m" : $"{months}m";
}
