@page "/admin"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject PetApiClient PetApi
@inject ISnackbar Snackbar

<PageTitle>Admin Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Pets" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h4" Class="mt-2">@_totalPets</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Pets</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                <MudText Typo="Typo.h4" Class="mt-2">@_available</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Available</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.BookmarkAdded" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h4" Class="mt-2">@_reserved</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Reserved</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Large" Color="Color.Info" />
                <MudText Typo="Typo.h4" Class="mt-2">@_adopted</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Adopted</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-6">
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/admin/pets">Manage Pets</MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" Href="/admin/pet-types">Pet Types</MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Tertiary" FullWidth="true" Href="/admin/announcements">Announcements</MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Dark" FullWidth="true" Href="/admin/users">Users</MudButton>
        </MudItem>
    </MudGrid>
}

@code {
    private long _totalPets, _available, _reserved, _adopted;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tasks = await Task.WhenAll(
                PetApi.GetPetsAsync(take: 0),
                PetApi.GetPetsAsync(status: "Available", take: 0),
                PetApi.GetPetsAsync(status: "Reserved", take: 0),
                PetApi.GetPetsAsync(status: "Adopted", take: 0)
            );
            _totalPets = tasks[0]?.Total ?? 0;
            _available = tasks[1]?.Total ?? 0;
            _reserved = tasks[2]?.Total ?? 0;
            _adopted = tasks[3]?.Total ?? 0;
        }
        catch { Snackbar.Add("Failed to load stats", Severity.Error); }
        finally { _loading = false; }
    }
}
