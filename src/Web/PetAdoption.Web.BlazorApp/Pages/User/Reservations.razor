@page "/reservations"
@layout MainLayout
@attribute [Authorize]
@inject PetApiClient PetApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>My Reservations</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">My Reservations</MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (!_requests.Any())
    {
        <MudText Typo="Typo.h6" Color="Color.Secondary" Align="Align.Center" Class="mt-8">
            No reservations yet.
        </MudText>
    }
    else
    {
        <MudGrid>
            @foreach (var req in _requests)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Warning">@(req.PetName.Length > 0 ? req.PetName[..1] : "?")</MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@req.PetName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@req.PetType</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Size="Size.Small" Color="Color.Primary"
                                OnClick="@(() => Navigation.NavigateTo($"/pets/{req.PetId}"))">View</MudButton>
                            <MudButton Size="Size.Small" Color="Color.Error"
                                OnClick="@(() => CancelRequest(req.Id))">Cancel</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<AdoptionRequestItem> _requests = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadReservations();

    private async Task LoadReservations()
    {
        _loading = true;
        try
        {
            var response = await PetApi.GetMyAdoptionRequestsAsync(take: 100);
            _requests = response?.Items?
                .Where(r => r.Status == "Pending")
                .ToList() ?? [];
        }
        catch { Snackbar.Add("Failed to load reservations", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task CancelRequest(Guid requestId)
    {
        try
        {
            var response = await PetApi.CancelAdoptionRequestAsync(requestId);
            if (response.IsSuccessStatusCode)
            {
                _requests.RemoveAll(r => r.Id == requestId);
                Snackbar.Add("Reservation cancelled", Severity.Info);
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiError>();
                Snackbar.Add(error?.Message ?? "Failed to cancel", Severity.Error);
            }
        }
        catch { Snackbar.Add("Connection error", Severity.Error); }
    }
}
