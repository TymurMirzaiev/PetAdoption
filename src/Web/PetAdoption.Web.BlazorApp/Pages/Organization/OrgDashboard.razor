@page "/org/{OrgId:guid}/dashboard"
@layout MainLayout
@attribute [Authorize]
@inject PetApiClient PetApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Org Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Organisation Dashboard</MudText>

@if (_kpiError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_kpiError</MudAlert>
}
else
{
    <MudGrid>
        <!-- KPI cards -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" Size="Size.Large" />
                @if (_kpiLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">@_kpi?.TotalPets</MudText>
                }
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Pets</MudText>
                @if (!_kpiLoading && _kpi is not null)
                {
                    <div class="d-flex gap-1 mt-1 flex-wrap justify-center">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@_kpi.AvailablePets available</MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">@_kpi.ReservedPets reserved</MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@_kpi.AdoptedPets adopted</MudChip>
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Large" />
                @if (_kpiLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">@(_kpi?.AdoptionRate.ToString("F1"))%</MudText>
                }
                <MudText Typo="Typo.body2" Color="Color.Secondary">Adoption Rate</MudText>
                @if (!_kpiLoading && _kpi is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_kpi.AdoptedPets adopted of @_kpi.TotalPets total</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Warning" Size="Size.Large" />
                @if (_kpiLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="60px" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">@_kpi?.TotalAdoptionRequests</MudText>
                }
                <MudText Typo="Typo.body2" Color="Color.Secondary">Adoption Requests</MudText>
                @if (!_kpiLoading && _kpi is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_kpi.PendingRequests pending</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Large" />
                @if (_kpiLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="80px" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">@_kpi?.TotalImpressions</MudText>
                }
                <MudText Typo="Typo.body2" Color="Color.Secondary">Impressions</MudText>
                @if (!_kpiLoading && _kpi is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Avg swipe rate: @(_kpi.AvgSwipeRate.ToString("F1"))%</MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- Date range pickers -->
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" sm="4" md="3">
                        <MudDatePicker Label="From" @bind-Date="_trendsFrom" DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudDatePicker Label="To" @bind-Date="_trendsTo" DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyTrendsDateRange">Apply</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Adoption trends chart -->
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="3" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Adoptions by Week</MudText>
                @if (_trendsError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_trendsError</MudAlert>
                }
                else if (_trendsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
                }
                else
                {
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="_adoptionSeries"
                              XAxisLabels="_trendsLabels"
                              Height="300"
                              Width="100%" />
                }
            </MudPaper>
        </MudItem>

        <!-- Requests trends chart -->
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="3" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Adoption Requests by Week</MudText>
                @if (_trendsError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_trendsError</MudAlert>
                }
                else if (_trendsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
                }
                else
                {
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="_requestsSeries"
                              XAxisLabels="_trendsLabels"
                              Height="300"
                              Width="100%" />
                }
            </MudPaper>
        </MudItem>

        <!-- Recent requests table -->
        <MudItem xs="12">
            <MudPaper Elevation="3" Class="pa-4">
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6">Recent Adoption Requests</MudText>
                    <MudLink Href="@($"/organization/{OrgId}/adoption-requests")">View all →</MudLink>
                </div>

                @if (_requestsError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_requestsError</MudAlert>
                }
                else if (_requestsLoading)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (!_recentRequests.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">No requests yet</MudText>
                }
                else
                {
                    <MudTable Items="_recentRequests" Hover="true" Elevation="0" Dense="true">
                        <HeaderContent>
                            <MudTh>Pet</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Message</MudTh>
                            <MudTh>Submitted</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.PetName</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@PetDisplayHelpers.RequestStatusColor(context.Status)">@context.Status</MudChip>
                            </MudTd>
                            <MudTd>@TruncateMessage(context.Message)</MudTd>
                            <MudTd>@RelativeTime(context.CreatedAt)</MudTd>
                            <MudTd>
                                @if (context.Status == "Pending")
                                {
                                    <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                        OnClick="@(() => ApproveRequest(context.Id))">Approve</MudButton>
                                    <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Text"
                                        OnClick="@(async () => await OpenRejectDialogAsync(context.Id, context.PetName))">Reject</MudButton>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid OrgId { get; set; }

    private OrgDashboardResponse? _kpi;
    private bool _kpiLoading = true;
    private string? _kpiError;

    private bool _trendsLoading = true;
    private string? _trendsError;
    private List<ChartSeries> _adoptionSeries = [];
    private List<ChartSeries> _requestsSeries = [];
    private string[] _trendsLabels = [];

    private List<OrgAdoptionRequestItem> _recentRequests = [];
    private bool _requestsLoading = true;
    private string? _requestsError;

    private DateTime? _trendsFrom = DateTime.UtcNow.AddDays(-84);
    private DateTime? _trendsTo = DateTime.UtcNow;


    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadKpisAsync(), LoadRecentRequestsAsync());
        _ = LoadTrendsAsync();
    }

    private async Task LoadKpisAsync()
    {
        _kpiLoading = true;
        _kpiError = null;
        try
        {
            _kpi = await PetApi.GetOrgDashboardAsync(OrgId);
        }
        catch
        {
            _kpiError = "Failed to load dashboard KPIs.";
        }
        finally
        {
            _kpiLoading = false;
        }
    }

    private async Task LoadRecentRequestsAsync()
    {
        _requestsLoading = true;
        _requestsError = null;
        try
        {
            var response = await PetApi.GetOrgAdoptionRequestsAsync(OrgId, status: null, take: 10);
            _recentRequests = response?.Items?.ToList() ?? [];
        }
        catch
        {
            _requestsError = "Failed to load recent requests.";
        }
        finally
        {
            _requestsLoading = false;
        }
    }

    private async Task LoadTrendsAsync()
    {
        _trendsLoading = true;
        _trendsError = null;
        try
        {
            var httpResponse = await PetApi.GetOrgDashboardTrendsAsync(OrgId, _trendsFrom, _trendsTo);
            if (!httpResponse.IsSuccessStatusCode)
            {
                var error = await httpResponse.Content.ReadFromJsonAsync<ApiError>();
                _trendsError = error?.Message ?? "Failed to load trends data.";
                Snackbar.Add(_trendsError, Severity.Error);
                return;
            }
            var response = await httpResponse.Content.ReadFromJsonAsync<OrgDashboardTrendsResponse>();
            if (response is not null)
            {
                _trendsLabels = response.AdoptionsByWeek.Select(p => p.Label).ToArray();
                _adoptionSeries =
                [
                    new ChartSeries
                    {
                        Name = "Adoptions",
                        Data = response.AdoptionsByWeek.Select(p => (double)p.Count).ToArray()
                    }
                ];
                _requestsSeries =
                [
                    new ChartSeries
                    {
                        Name = "Requests",
                        Data = response.RequestsByWeek.Select(p => (double)p.Count).ToArray()
                    }
                ];
            }
        }
        catch
        {
            _trendsError = "Failed to load trends data.";
            Snackbar.Add(_trendsError, Severity.Error);
        }
        finally
        {
            _trendsLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyTrendsDateRange()
    {
        await LoadTrendsAsync();
    }

    private async Task ApproveRequest(Guid requestId)
    {
        try
        {
            var response = await PetApi.ApproveAdoptionRequestAsync(requestId);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Request approved!", Severity.Success);
                await LoadRecentRequestsAsync();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiError>();
                Snackbar.Add(error?.Message ?? "Failed to approve", Severity.Error);
            }
        }
        catch { Snackbar.Add("Connection error", Severity.Error); }
    }

    private async Task OpenRejectDialogAsync(Guid requestId, string petName)
    {
        var parameters = new DialogParameters<RejectRequestDialog>
        {
            { x => x.PetName, petName }
        };
        var dialog = await DialogService.ShowAsync<RejectRequestDialog>($"Reject adoption for {petName}", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is string reason)
        {
            try
            {
                var response = await PetApi.RejectAdoptionRequestAsync(requestId, reason);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Request rejected", Severity.Info);
                    await LoadRecentRequestsAsync();
                }
                else
                {
                    var error = await response.Content.ReadFromJsonAsync<ApiError>();
                    Snackbar.Add(error?.Message ?? "Failed to reject", Severity.Error);
                }
            }
            catch { Snackbar.Add("Connection error", Severity.Error); }
        }
    }

    private static string TruncateMessage(string? message)
    {
        if (string.IsNullOrEmpty(message)) return "-";
        return message.Length > 60 ? message[..60] + "…" : message;
    }

    private static string RelativeTime(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt;
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays} day{((int)diff.TotalDays == 1 ? "" : "s")} ago";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours} hour{((int)diff.TotalHours == 1 ? "" : "s")} ago";
        return $"{(int)diff.TotalMinutes} minute{((int)diff.TotalMinutes == 1 ? "" : "s")} ago";
    }

}
