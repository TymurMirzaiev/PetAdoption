@page "/pets/{Id:guid}"
@layout MainLayout
@attribute [Authorize]
@inject PetApiClient PetApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Pet Details</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    @if (_loading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="300px" />
    }
    else if (_pet is null)
    {
        <MudText Typo="Typo.h6" Color="Color.Error">Pet not found.</MudText>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="3">
            <div class="d-flex align-center mb-4">
                <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">@(_pet.Name.Length > 0 ? _pet.Name[..1] : "?")</MudAvatar>
                <div>
                    <MudText Typo="Typo.h4">@_pet.Name</MudText>
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@_pet.Type</MudText>
                </div>
                <MudSpacer />
                <MudChip T="string" Color="@PetDisplayHelpers.PetStatusColor(_pet.Status)">@_pet.Status</MudChip>
            </div>

            <PetMediaGallery PetId="@Id" ReadOnly="true" Class="mb-4" />

            @if (_pet.Breed is not null)
            {
                <MudText Typo="Typo.body1" Class="mb-2"><b>Breed:</b> @_pet.Breed</MudText>
            }
            @if (_pet.AgeMonths.HasValue)
            {
                <MudText Typo="Typo.body1" Class="mb-2"><b>Age:</b> @PetDisplayHelpers.FormatAge(_pet.AgeMonths.Value)</MudText>
            }
            @if (_pet.Description is not null)
            {
                <MudText Typo="Typo.body1" Class="mb-4">@_pet.Description</MudText>
            }

            @if (_pet.MedicalRecord is not null)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">Medical Information</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudChip T="string" Color="@(_pet.MedicalRecord.IsSpayedNeutered ? Color.Success : Color.Default)" Size="Size.Small">
                            @(_pet.MedicalRecord.IsSpayedNeutered ? "Spayed/Neutered" : "Not Spayed/Neutered")
                        </MudChip>
                        @if (_pet.MedicalRecord.SpayNeuterDate.HasValue)
                        {
                            <MudText Typo="Typo.caption" Class="mt-1">Date: @_pet.MedicalRecord.SpayNeuterDate.Value.ToString("yyyy-MM-dd")</MudText>
                        }
                    </MudItem>
                    @if (_pet.MedicalRecord.MicrochipId is not null)
                    {
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2"><b>Microchip:</b> <code>@_pet.MedicalRecord.MicrochipId</code></MudText>
                        </MudItem>
                    }
                    @if (_pet.MedicalRecord.LastVetVisit.HasValue)
                    {
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2"><b>Last Vet Visit:</b> @_pet.MedicalRecord.LastVetVisit.Value.ToString("yyyy-MM-dd")</MudText>
                        </MudItem>
                    }
                </MudGrid>

                @if (_pet.MedicalRecord.Allergies.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Allergies</MudText>
                    <MudChipSet T="string" ReadOnly="true">
                        @foreach (var allergy in _pet.MedicalRecord.Allergies)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@allergy</MudChip>
                        }
                    </MudChipSet>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Secondary">No known allergies</MudText>
                }

                @if (_pet.MedicalRecord.Vaccinations.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Vaccinations</MudText>
                    <MudSimpleTable Dense="true" Hover="true" Class="mb-3">
                        <thead>
                            <tr>
                                <th>Vaccine</th>
                                <th>Administered</th>
                                <th>Next Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vax in _pet.MedicalRecord.Vaccinations.OrderByDescending(v => v.AdministeredOn))
                            {
                                <tr>
                                    <td>@vax.VaccineType</td>
                                    <td>@vax.AdministeredOn.ToString("yyyy-MM-dd")</td>
                                    <td style="@(vax.NextDueOn.HasValue && vax.NextDueOn.Value < DateOnly.FromDateTime(DateTime.Today) ? "color:red;" : "")">
                                        @(vax.NextDueOn?.ToString("yyyy-MM-dd") ?? "-")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }

                @if (_pet.MedicalRecord.History is not null)
                {
                    <MudExpansionPanels Class="mt-2">
                        <MudExpansionPanel Text="Show medical history notes">
                            <MudText Typo="Typo.body2">@_pet.MedicalRecord.History</MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            }

            <MudDivider Class="my-4" />

            <div class="d-flex gap-2">
                <MudIconButton Icon="@(_isFavorited ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)"
                    Color="@(_isFavorited ? Color.Error : Color.Default)"
                    OnClick="ToggleFavorite" Disabled="_actionLoading" />
                @if (_pet.Status == "Available")
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.BookmarkAdd"
                        OnClick="Reserve" Disabled="_actionLoading">Request Adoption</MudButton>
                }
                <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/discover"))">Back</MudButton>
            </div>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public Guid Id { get; set; }

    private PetDetails? _pet;
    private bool _loading = true;
    private bool _actionLoading;
    private bool _isFavorited;

    protected override async Task OnInitializedAsync()
    {
        try { _pet = await PetApi.GetPetAsync(Id); }
        catch { Snackbar.Add("Failed to load pet details", Severity.Error); }
        finally { _loading = false; }

        _isFavorited = await PetApi.CheckFavoriteAsync(Id);
    }

    private async Task ToggleFavorite()
    {
        _actionLoading = true;
        try
        {
            if (_isFavorited)
            {
                var response = await PetApi.RemoveFavoriteAsync(Id);
                if (response.IsSuccessStatusCode)
                {
                    _isFavorited = false;
                    Snackbar.Add("Removed from favorites", Severity.Info);
                }
                else
                {
                    Snackbar.Add("Could not update favorite — please try again.", Severity.Warning);
                }
            }
            else
            {
                var response = await PetApi.AddFavoriteAsync(Id);
                if (response.IsSuccessStatusCode)
                {
                    _isFavorited = true;
                    Snackbar.Add("Added to favorites!", Severity.Success);
                }
                else
                {
                    Snackbar.Add("Could not update favorite — please try again.", Severity.Warning);
                }
            }
        }
        catch { Snackbar.Add("Failed to update favorite", Severity.Error); }
        finally { _actionLoading = false; }
    }

    private async Task Reserve()
    {
        _actionLoading = true;
        try
        {
            if (_pet!.OrganizationId.HasValue)
            {
                var response = await PetApi.CreateAdoptionRequestAsync(_pet.Id);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Adoption request submitted!", Severity.Success);
                    _pet = await PetApi.GetPetAsync(Id);
                }
                else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
                {
                    Snackbar.Add("You already have a pending request for this pet.", Severity.Info);
                }
                else
                {
                    var error = await response.Content.ReadFromJsonAsync<ApiError>();
                    Snackbar.Add(error?.Message ?? "Failed to submit request", Severity.Error);
                }
            }
            else
            {
                var response = await PetApi.ReservePetAsync(Id);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Pet reserved!", Severity.Success);
                    _pet = await PetApi.GetPetAsync(Id);
                }
                else
                {
                    var error = await response.Content.ReadFromJsonAsync<ApiError>();
                    Snackbar.Add(error?.Message ?? "Failed to reserve", Severity.Error);
                }
            }
        }
        catch { Snackbar.Add("Connection error", Severity.Error); }
        finally { _actionLoading = false; }
    }

}
