@page "/discover"
@layout MainLayout
@attribute [Authorize]
@inject PetApiClient PetApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav

<PageTitle>Discover Pets</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">

    @* Location Chip *@
    <div class="d-flex align-center mb-3 gap-2">
        <MudChip T="string"
                 Icon="@Icons.Material.Filled.LocationOn"
                 Color="@(_locationActive ? Color.Primary : Color.Default)"
                 Variant="@(_locationActive ? Variant.Filled : Variant.Outlined)"
                 OnClick="OpenLocationDialog">
            @(_locationActive ? $"Within {_radiusKm} km" : "Set location")
        </MudChip>
        @if (_locationActive)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="ClearLocation" />
        }
    </div>

    @* Filter Panel *@
    <MudExpansionPanels Class="mb-4">
        <MudExpansionPanel Text="Filters">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" Label="Pet Type" @bind-Value="_selectedTypeId" Clearable="true">
                        @if (_petTypes is not null)
                        {
                            @foreach (var pt in _petTypes)
                            {
                                <MudSelectItem Value="@((Guid?)pt.Id)">@pt.Name</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string?" Label="Age Range" @bind-Value="_ageRange" Clearable="true">
                        <MudSelectItem Value="@((string?)"0-6")">Under 6 months</MudSelectItem>
                        <MudSelectItem Value="@((string?)"6-12")">6–12 months</MudSelectItem>
                        <MudSelectItem Value="@((string?)"12-24")">1–2 years</MudSelectItem>
                        <MudSelectItem Value="@((string?)"24-60")">2–5 years</MudSelectItem>
                        <MudSelectItem Value="@((string?)"60-")">5+ years</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Breed contains" @bind-Value="_breedSearch" Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-end">
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters">
                            Apply Filters
                        </MudButton>
                        <MudButton Variant="Variant.Text" OnClick="ClearFilters">Clear</MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <div class="d-flex justify-end mb-2">
        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.HelpOutline" OnClick="ShowOnboarding">
            Show tutorial
        </MudButton>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center mt-8">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="300px" Height="420px" />
        </div>
    }
    else if (!_pets.Any())
    {
        <div class="d-flex flex-column align-center mt-8 gap-4">
            <MudIcon Icon="@Icons.Material.Filled.Pets" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Secondary">
                You've seen all available pets matching your filters!
            </MudText>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResetAndReload">
                    Reset and discover again
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@(() => Nav.NavigateTo("/favorites"))">
                    View favorites
                </MudButton>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex justify-center">
            <SwipeCardStack Pets="_pets" OnFavorite="HandleFavorite" OnSkip="HandleSkip" OnNeedMore="LoadMore" />
        </div>
    }
</MudContainer>

@code {
    private List<PetListItem> _pets = [];
    private List<PetTypeItem>? _petTypes;
    private bool _loading = true;
    private bool _hasMore = true;
    private const string OnboardingSeenKey = "petadoption_onboarding_seen";
    private const string LocationStorageKey = "petadoption_discover_location";

    // Filter state
    private Guid? _selectedTypeId;
    private string? _ageRange;
    private string? _breedSearch;

    private static (int? min, int? max) ParseAgeRange(string? range) => range switch
    {
        "0-6"   => (0,   6),
        "6-12"  => (6,   12),
        "12-24" => (12,  24),
        "24-60" => (24,  60),
        "60-"   => (60,  null),
        _       => (null, null)
    };

    // Location state
    private decimal? _locationLat;
    private decimal? _locationLng;
    private int _radiusKm = 50;
    private bool _locationActive => _locationLat.HasValue && _locationLng.HasValue && _radiusKm > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadPetTypes();
        await RestoreLocationFromStorage();
        await LoadPets();
    }

    private async Task RestoreLocationFromStorage()
    {
        try
        {
            var stored = await LocalStorage.GetAsync(LocationStorageKey);
            if (!string.IsNullOrEmpty(stored))
            {
                var parts = stored.Split(',');
                if (parts.Length == 3
                    && decimal.TryParse(parts[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat)
                    && decimal.TryParse(parts[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lng)
                    && int.TryParse(parts[2], out var radius) && radius > 0)
                {
                    _locationLat = lat;
                    _locationLng = lng;
                    _radiusKm = radius;
                }
            }
        }
        catch { }
    }

    private async Task SaveLocationToStorage()
    {
        try
        {
            if (_locationLat.HasValue && _locationLng.HasValue)
            {
                var value = $"{_locationLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)},{_locationLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)},{_radiusKm}";
                await LocalStorage.SetAsync(LocationStorageKey, value);
            }
            else
            {
                await LocalStorage.RemoveAsync(LocationStorageKey);
            }
        }
        catch { }
    }

    private async Task OpenLocationDialog()
    {
        var parameters = new DialogParameters
        {
            ["InitialLat"] = _locationLat,
            ["InitialLng"] = _locationLng,
            ["InitialRadius"] = _radiusKm
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LocationDialog>("Set Location", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: LocationDialogResult locationResult })
        {
            if (locationResult.RadiusKm > 0 && locationResult.Lat.HasValue && locationResult.Lng.HasValue)
            {
                _locationLat = locationResult.Lat;
                _locationLng = locationResult.Lng;
                _radiusKm = locationResult.RadiusKm;
            }
            else
            {
                _locationLat = null;
                _locationLng = null;
            }
            await SaveLocationToStorage();
            await LoadPets();
        }
    }

    private async Task ClearLocation()
    {
        _locationLat = null;
        _locationLng = null;
        await SaveLocationToStorage();
        await LoadPets();
    }

    private async Task LoadPetTypes()
    {
        try
        {
            var response = await PetApi.GetPublicPetTypesAsync();
            _petTypes = response?.Items?.ToList();
        }
        catch { }
    }

    private async Task LoadPets()
    {
        _loading = true;
        _pets.Clear();
        _hasMore = true;
        await FetchBatch();
        _loading = false;
    }

    private async Task FetchBatch()
    {
        if (!_hasMore) return;
        try
        {
            var (minAge, maxAge) = ParseAgeRange(_ageRange);
            var response = await PetApi.GetDiscoverPetsAsync(
                petTypeId: _selectedTypeId,
                minAge: minAge,
                maxAge: maxAge,
                take: 10,
                breed: _breedSearch,
                lat: _locationActive ? _locationLat : null,
                lng: _locationActive ? _locationLng : null,
                radiusKm: _locationActive ? _radiusKm : null);
            if (response?.Pets is not null)
            {
                var newPets = response.Pets.ToList();
                _pets.AddRange(newPets);
                _hasMore = response.HasMore;

                // Fire-and-forget: track impressions for loaded pets
                if (newPets.Any())
                {
                    _ = PetApi.TrackBatchImpressionsAsync(newPets.Select(p => p.Id));
                }
            }
        }
        catch
        {
            Snackbar.Add("Failed to load pets", Severity.Error);
        }
    }

    private async Task ApplyFilters() => await LoadPets();

    private async Task ClearFilters()
    {
        _selectedTypeId = null;
        _ageRange = null;
        _breedSearch = null;
        await LoadPets();
    }

    private async Task HandleFavorite(PetListItem pet)
    {
        _ = PetApi.TrackInteractionAsync(pet.Id, "Swipe");

        try
        {
            var response = await PetApi.AddFavoriteAsync(pet.Id);
            if (!response.IsSuccessStatusCode && response.StatusCode != System.Net.HttpStatusCode.Conflict)
            {
                Snackbar.Add("Failed to add favorite", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Connection error", Severity.Error);
        }
    }

    private async Task HandleSkip(PetListItem pet)
    {
        // Analytics: track rejection event (Plan 13 -- PetInteraction)
        _ = PetApi.TrackInteractionAsync(pet.Id, "Rejection");

        // Discovery feed exclusion: track skip so this pet won't reappear
        try
        {
            var response = await PetApi.TrackSkipAsync(pet.Id);
            if (!response.IsSuccessStatusCode && response.StatusCode != System.Net.HttpStatusCode.Conflict)
            {
                // Non-critical -- skip tracking failure shouldn't block the UX
                Snackbar.Add("Failed to track skip", Severity.Warning);
            }
        }
        catch
        {
            // Silently fail -- skip tracking is best-effort from UX perspective
        }
    }

    private async Task LoadMore() => await FetchBatch();

    private async Task ResetAndReload()
    {
        try
        {
            var response = await PetApi.ResetSkipsAsync();
            if (response.IsSuccessStatusCode)
            {
                await LoadPets();
                Snackbar.Add("Skips reset! Discover pets again.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to reset skips", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Connection error", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckOnboarding();
        }
    }

    private async Task CheckOnboarding()
    {
        try
        {
            var seen = await LocalStorage.GetAsync(OnboardingSeenKey);
            if (string.IsNullOrEmpty(seen))
            {
                await ShowOnboarding();
            }
        }
        catch
        {
            // localStorage may not be available; skip silently
        }
    }

    private async Task ShowOnboarding()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            NoHeader = true,
            CloseOnEscapeKey = false,
            BackdropClick = false
        };
        var dialog = await DialogService.ShowAsync<OnboardingDialog>("Welcome", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            try
            {
                await LocalStorage.SetAsync(OnboardingSeenKey, "true");
            }
            catch { }
        }
    }
}
