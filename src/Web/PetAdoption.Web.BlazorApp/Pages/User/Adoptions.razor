@page "/adoptions"
@layout MainLayout
@attribute [Authorize]
@inject PetApiClient PetApi
@inject ISnackbar Snackbar

<PageTitle>My Adoptions</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">My Adoptions</MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (!_requests.Any())
    {
        <MudText Typo="Typo.h6" Color="Color.Secondary" Align="Align.Center" Class="mt-8">
            No adoptions yet. Start by discovering and reserving a pet!
        </MudText>
    }
    else
    {
        <MudGrid>
            @foreach (var req in _requests)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Info">@(req.PetName.Length > 0 ? req.PetName[..1] : "?")</MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@req.PetName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@req.PetType</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Adopted</MudChip>
                            @if (req.ReviewedAt.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                    Adopted on @req.ReviewedAt.Value.ToLocalTime().ToString("d")
                                </MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<AdoptionRequestItem> _requests = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await PetApi.GetMyAdoptionRequestsAsync(take: 100);
            _requests = response?.Items?
                .Where(r => r.Status == "Approved")
                .ToList() ?? [];
        }
        catch { Snackbar.Add("Failed to load adoptions", Severity.Error); }
        finally { _loading = false; }
    }

}
