@using PetAdoption.Web.BlazorApp.Models
@inject IJSRuntime JS

<div class="d-flex flex-column align-center">
    @if (_pets.Any())
    {
        <div class="swipe-card-area" id="@_containerId">
            <div class="swipe-hint swipe-hint--adopt" style="opacity: @HintOpacity("adopt")">ADOPT</div>
            <div class="swipe-hint swipe-hint--reject" style="opacity: @HintOpacity("reject")">NOPE</div>

            @for (var i = Math.Min(_pets.Count - 1, 2); i >= 0; i--)
            {
                var pet = _pets[i];
                var isTop = i == 0;
                var offset = i * 4;
                var scale = 1.0 - i * 0.03;
                var zIndex = 10 - i;

                var style = $"position:absolute;top:{offset}px;left:{offset}px;transform-origin:top left;z-index:{zIndex};";
                if (isTop)
                {
                    var dragTransform = _dragging
                        ? $"translateX({_offsetX:F0}px) rotate({_offsetX * 0.04:F1}deg) scale(1)"
                        : "scale(1)";
                    style += $"transform:{dragTransform};";

                    <div class="swipe-top-card @(_dragging ? "dragging" : "")" style="@style"
                         @ontouchstart="OnTouchStart" @ontouchstart:preventDefault
                         @ontouchmove="OnTouchMove" @ontouchmove:preventDefault
                         @ontouchend="OnTouchEnd"
                         @onmousedown="OnMouseDown"
                         @onmousemove="OnMouseMove"
                         @onmouseup="OnMouseUp"
                         @onmouseleave="OnMouseUp">
                        <PetCard Pet="pet" />
                    </div>
                }
                else
                {
                    style += $"transform:scale({scale:F2});";
                    <div style="@style">
                        <PetCard Pet="pet" />
                    </div>
                }
            }
        </div>

        <div class="d-flex gap-4 mt-4">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Large"
                OnClick="() => TriggerAction(false)" Variant="Variant.Outlined" Disabled="_animating" />
            <MudIconButton Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" Size="Size.Large"
                OnClick="() => TriggerAction(true)" Variant="Variant.Outlined" Disabled="_animating" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<PetListItem> Pets { get; set; } = [];
    [Parameter] public EventCallback<PetListItem> OnFavorite { get; set; }
    [Parameter] public EventCallback<PetListItem> OnSkip { get; set; }
    [Parameter] public EventCallback OnNeedMore { get; set; }

    private List<PetListItem> _pets = [];

    protected override void OnParametersSet()
    {
        _pets = Pets?.ToList() ?? [];
    }

    private double _offsetX;
    private double _startX;
    private bool _dragging;
    private bool _animating;
    private const double SwipeThreshold = 80;

    private readonly string _containerId = $"swipe-stack-{Guid.NewGuid():N}";

    private string HintOpacity(string action)
    {
        if (!_dragging) return "0";
        var progress = Math.Min(Math.Abs(_offsetX) / SwipeThreshold, 1.0);
        if (action == "adopt" && _offsetX > 20) return progress.ToString("F2");
        if (action == "reject" && _offsetX < -20) return progress.ToString("F2");
        return "0";
    }

    private void OnTouchStart(TouchEventArgs e)
    {
        if (_animating) return;
        _startX = e.ChangedTouches[0].ClientX;
        _dragging = true;
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (!_dragging) return;
        _offsetX = e.ChangedTouches[0].ClientX - _startX;
    }

    private async Task OnTouchEnd(TouchEventArgs e)
    {
        if (!_dragging) return;
        _dragging = false;
        if (Math.Abs(_offsetX) > SwipeThreshold)
        {
            var isFavorite = _offsetX > 0;
            await PlayAnimationAndRemove(isFavorite, _offsetX * 0.85);
        }
        _offsetX = 0;
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        if (_animating) return;
        _startX = e.ClientX;
        _dragging = true;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (!_dragging) return;
        _offsetX = e.ClientX - _startX;
    }

    private async Task OnMouseUp(MouseEventArgs e)
    {
        if (!_dragging) return;
        _dragging = false;
        if (Math.Abs(_offsetX) > SwipeThreshold)
        {
            var isFavorite = _offsetX > 0;
            await PlayAnimationAndRemove(isFavorite, _offsetX * 0.85);
        }
        _offsetX = 0;
    }

    private async Task TriggerAction(bool isFavorite)
    {
        if (_animating || !_pets.Any()) return;
        await PlayAnimationAndRemove(isFavorite, 0);
    }

    private async Task PlayAnimationAndRemove(bool isFavorite, double dragOffset)
    {
        if (!_pets.Any()) return;
        _animating = true;
        _offsetX = 0;
        StateHasChanged();

        var pet = _pets[0];
        var action = isFavorite ? "adopt" : "reject";
        var selector = $"#{_containerId}";

        try
        {
            await JS.InvokeVoidAsync("swipeAnimations.playSwipeAnimation", selector, action, pet.Type, dragOffset);
        }
        catch
        {
            // JS interop can fail if component disposes during animation
        }

        _pets.RemoveAt(0);
        _animating = false;
        StateHasChanged();

        if (isFavorite)
            await OnFavorite.InvokeAsync(pet);
        else
            await OnSkip.InvokeAsync(pet);

        await CheckNeedMore();
    }

    private async Task CheckNeedMore()
    {
        if (_pets.Count <= 3)
            await OnNeedMore.InvokeAsync();
    }
}
