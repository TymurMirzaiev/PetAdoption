@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject JwtAuthenticationStateProvider AuthProvider
@inject PetApiClient PetApi
@implements IDisposable

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">PetAdoption</MudText>
        <MudSpacer />
        <AuthorizeView Context="authContext">
            <Authorized>
                <AuthorizeView Roles="Admin" Context="adminContext">
                    <MudButton Color="Color.Inherit" Href="/admin">Admin</MudButton>
                </AuthorizeView>
                @{
                    var orgId = authContext.User.FindFirst("organizationId")?.Value;
                }
                @if (!string.IsNullOrEmpty(orgId))
                {
                    <MudButton Color="Color.Inherit" Href="@($"/org/{orgId}/dashboard")">Dashboard</MudButton>
                    <MudButton Color="Color.Inherit" Href="@($"/org/{orgId}/pets")">Org Pets</MudButton>
                    <MudBadge Content="@(_orgUnread > 0 ? _orgUnread.ToString() : null)" Color="Color.Error" Overlap="true" Bordered="true">
                        <MudButton Color="Color.Inherit" Href="@($"/organization/{orgId}/adoption-requests")">Adoption Requests</MudButton>
                    </MudBadge>
                    <MudButton Color="Color.Inherit" Href="@($"/org/{orgId}/metrics")">Metrics</MudButton>
                }
                <MudButton Color="Color.Inherit" Href="/discover">Discover</MudButton>
                <MudButton Color="Color.Inherit" Href="/favorites">Favorites</MudButton>
                <MudButton Color="Color.Inherit" Href="/reservations">Reservations</MudButton>
                <MudBadge Content="@(_myUnread > 0 ? _myUnread.ToString() : null)" Color="Color.Error" Overlap="true" Bordered="true">
                    <MudButton Color="Color.Inherit" Href="/my-adoption-requests">My Requests</MudButton>
                </MudBadge>
                <MudButton Color="Color.Inherit" Href="/profile">Profile</MudButton>
                <MudButton Color="Color.Inherit" OnClick="LogoutAsync">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login">Login</MudButton>
                <MudButton Color="Color.Inherit" Href="/register">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent>
        <AnnouncementBanner />
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private int _myUnread;
    private int _orgUnread;
    private Timer? _pollTimer;
    private string? _orgId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            _orgId = authState.User.FindFirst("organizationId")?.Value;
            await PollUnreadAsync();
            _pollTimer = new Timer(_ => InvokeAsync(async () =>
            {
                await PollUnreadAsync();
                StateHasChanged();
            }), null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
    }

    private async Task PollUnreadAsync()
    {
        try { _myUnread = await PetApi.GetMyChatUnreadTotalAsync(); } catch { }
        if (!string.IsNullOrEmpty(_orgId) && Guid.TryParse(_orgId, out var oid))
        {
            try { _orgUnread = await PetApi.GetOrgChatUnreadTotalAsync(oid); } catch { }
        }
    }

    private async Task LogoutAsync()
    {
        _pollTimer?.Dispose();
        await AuthProvider.Logout();
        Navigation.NavigateTo("/");
    }

    public void Dispose() => _pollTimer?.Dispose();
}
